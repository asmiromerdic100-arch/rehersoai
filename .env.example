# ──────────────────────────────────────────────────────────────
# Supabase (required)
# Get these from https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# AI Providers
# Gemini:  https://aistudio.google.com/app/apikey   (free tier: ~1500 req/day)
# Groq:    https://console.groq.com/keys            (free tier: generous)
# ──────────────────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=
GROQ_API_KEY=

# Provider selection. Use 'mock' during early dev to avoid API calls.
# evaluator: 'gemini' | 'groq' | 'mock'
# transcriber: 'groq' | 'mock'
EVALUATOR_PROVIDER=mock
TRANSCRIBER_PROVIDER=mock

# ──────────────────────────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
